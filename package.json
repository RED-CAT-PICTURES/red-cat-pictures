{
  "name": "red-cat-pictures",
  "version": "3.14.1",
  "description": "Tech-enabled Creative Media Agency",
  "author": "Shirsendu Bairagi <shirsendu2001@gmail.com>",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RED-CAT-PICTURES/red-cat-pictures.git"
  },
  "type": "module",
  "private": true,
  "engines": {
    "node": "^22.11.0 || ^24.14.0",
    "pnpm": "^9.15.0 || ^10.2.0",
    "bun": "^1.2.9"
  },
  "packageManager": "bun@1.3.13",
  "scripts": {
    "prepare": "husky || true",
    "postinstall": "nuxt prepare",
    "dev": "nuxt dev",
    "detect": "gitleaks git --verbose",
    "lint": "eslint . --fix",
    "format": "prettier . --write",
    "test:load": "k6 run tests/load.test.ts",
    "build": "nuxt build && (cp -r static .output/static || true)",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node --env-file=.env.prod .output/server/index.mjs",
    "clean": "nuxt cleanup && (cd src-tauri && cargo clean)",
    "docker:build": "docker build --build-arg TAG=dev -t red-cat-pictures:dev .",
    "docker:start": "docker run --detach --name red-cat-pictures-dev --mount type=bind,source=$(pwd)/static,target=/app/static --env-file .env.prod -p 4300:3000 red-cat-pictures:dev",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:dev:mobile": "tauri android dev",
    "tauri:build:mobile": "tauri android build",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:unit": "vitest --project unit",
    "test:nuxt": "vitest --project nuxt"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.65.0",
    "@hannoeru/nuxt-otel": "^0.0.8",
    "@notionhq/client": "^5.21.0",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.0.6",
    "@nuxt/test-utils": "^4.0.3",
    "@nuxtjs/color-mode": "^4.0.0",
    "@nuxtjs/mcp-toolkit": "^0.16.1",
    "@nuxtjs/mdc": "^0.21.1",
    "@nuxtjs/seo": "^5.1.3",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@shba007/unai": "^0.3.9",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tresjs/cientos": "^5.7.1",
    "@tresjs/nuxt": "^5.6.1",
    "@types/k6": "^2.0.0",
    "@types/markdown-it": "^14.1.2",
    "@types/web-push": "^3.6.4",
    "@unhead/vue": "^2.1.15",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "date-fns": "^4.1.0",
    "eslint": "^10.3.0",
    "fast-xml-parser": "^5.8.0",
    "hast-util-from-html": "^2.0.3",
    "hast-util-select": "^6.0.4",
    "magic-regexp": "^0.11.0",
    "markdown-it": "^14.1.1",
    "notion-to-md": "^3.1.9",
    "nuxt": "^4.4.5",
    "p-map": "^7.0.4",
    "puppeteer": "^24.43.1",
    "regl": "^2.1.1",
    "rehype-parse": "^9.0.1",
    "rehype-remark": "^10.0.1",
    "remark-stringify": "^11.0.0",
    "rx-player": "^4.4.1",
    "three": "^0.184.0",
    "unified": "^11.0.5",
    "vue": "latest",
    "vue-router": "latest",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@tauri-apps/cli": "^2.11.1",
    "@types/bun": "^1.3.13",
    "@vitest/coverage-v8": "^4.1.6",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "playwright-core": "^1.60.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "vitest": "^4.1.6"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "esbuild",
    "protobufjs",
    "puppeteer",
    "sharp",
    "unrs-resolver",
    "vue-demi"
  ]
}
